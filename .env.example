# ─────────────────────────────────────────────────────────────────────────────
# DEXignation contracts — environment variables example.
# Copy to `.env` and fill in your values. NEVER commit your real `.env`.
#
# DEXignation 컨트랙트용 환경 변수 예시. `.env`로 복사 후 값을 채우세요.
# 실제 `.env`는 절대 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────────────────────

# ── RPC endpoints ────────────────────────────────────────────────────────────
# Public RPCs work but are rate-limited. Use Alchemy/Infura/QuickNode for prod.
# 공용 RPC는 동작하지만 rate-limit이 있습니다. 운영에는 Alchemy/Infura/QuickNode 권장.
POLYGON_RPC_URL=https://polygon-rpc.com
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ── Deployer key ─────────────────────────────────────────────────────────────
# 0x-prefixed private key. NEVER commit your real key. Use a fresh key
# funded with only what you need to deploy.
# 0x로 시작하는 프라이빗 키. 절대 커밋 금지. 배포에 필요한 만큼만 가스가
# 들어 있는 신규 키 사용 권장.
DEPLOYER_PRIVATE_KEY=

# ── Polygonscan API key (for `hardhat verify`) ───────────────────────────────
# Polygonscan API 키 (컨트랙트 verify용).
POLYGONSCAN_API_KEY=

# ── Chainlink oracle addresses (mainnet) ─────────────────────────────────────
# POL/USD direct feed on Polygon mainnet. Update if Chainlink republishes
# under a new address.
# Polygon 메인넷의 POL/USD 직접 피드. Chainlink가 새 주소로 재발행하면 갱신.
CHAINLINK_POL_USD_POLYGON=0xAB594600376Ec9fD91F8e885dADF0CE036862dE0
CHAINLINK_LINK_USD_POLYGON=0xd9FFdb71EbE7496cC440152d43986Aae0AB76665
CHAINLINK_LINK_MATIC_POLYGON=0x5787BefDc0ECd210Dfa948264631CD53E68F7802

# ── Test stablecoin addresses ────────────────────────────────────────────────
# Real USDT / USDC on Polygon mainnet. For Amoy, set Mock addresses after
# the testnet deployment.
# Polygon 메인넷의 실제 USDT / USDC 주소. Amoy는 테스트 배포 후 Mock 주소로 설정.
USDT_POLYGON=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
USDC_POLYGON=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
